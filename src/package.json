{
  "name": "irl-lvp-up",
  "version": "1.9.170",
  "description": "Ton RPG de vie local",
  "main": "electron-main.cjs",
  "author": "Adrien",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win",
    "release": "electron-builder --win -p always",
    "test": "node --test test/logic.test.js test/foods.test.js test/icons.test.js test/css-lint.test.js test/pwa.test.js",
    "test:smoke": "electron test/renderer-smoke.cjs",
    "verify": "npm test && npm run test:smoke"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.adrien.irllvpup",
    "productName": "IRL LVP UP",
    "directories": {
      "output": "../build-dist"
    },
    "files": [
      "index.html",
      "app.js",
      "lib/**/*",
      "electron-main.cjs",
      "preload.cjs",
      "*.css",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "adrienlvl",
        "repo": "irl-lvp-up"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
